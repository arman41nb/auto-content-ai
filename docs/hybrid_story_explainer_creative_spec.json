{
  "template": "hybrid_story_explainer",
  "preferred_production_template": true,
  "brand_style": [
    "intelligent",
    "visual",
    "story-driven",
    "social-first",
    "clean",
    "premium",
    "not childish",
    "not PowerPoint",
    "not AI-trash",
    "not generic slideshow"
  ],
  "viewer_feeling": [
    "Now I understand",
    "That was a clear example",
    "This is worth saving",
    "This is worth sending to someone"
  ],
  "default_scene_count": 8,
  "structure": [
    "hook_with_real_world_context",
    "question_from_proxy",
    "concrete_setup",
    "mechanism_visualized",
    "real_world_consequence",
    "contrast",
    "nuance",
    "takeaway"
  ],
  "core_rule": "Every scene must be a meaningful scene, not just a picture with a title.",
  "mascot_role": {
    "should_be": [
      "guide",
      "explainer",
      "commentator",
      "pointer",
      "reaction character",
      "visual memory device"
    ],
    "should_not_be": [
      "giant central subject in most scenes",
      "decorative filler",
      "replacement for context",
      "unrelated toy in front of random background",
      "stretched or cropped awkwardly"
    ],
    "frame_share_target": {
      "normal_min": 0.1,
      "normal_max": 0.35,
      "hard_fail_above": 0.45
    }
  },
  "proxy_roles": [
    "importer",
    "business_owner",
    "student",
    "curious_friend",
    "market_watcher",
    "shipping_manager",
    "shopper"
  ],
  "caption_style": {
    "name": "hybrid_editorial",
    "caption_box_max_frame_ratio": 0.12,
    "hook_takeaway_max_frame_ratio": 0.18
  },
  "economy_safety": [
    "no financial advice",
    "no trading recommendations",
    "include nuance",
    "describe indirect or context-dependent links",
    "distinguish importers and exporters when relevant"
  ]
}
